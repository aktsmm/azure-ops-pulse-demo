{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aktsmm.github.io/azure-ops-pulse-demo/schemas/public/v1/snapshot.schema.json",
  "title": "Azure Ops Pulse public snapshot v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "mode",
    "freshness",
    "scope",
    "sources",
    "overview",
    "cost",
    "inventory",
    "reliability",
    "security",
    "network",
    "aiInsights"
  ],
  "properties": {
    "schemaVersion": { "const": "1.1.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "mode": { "enum": ["DEMO", "AZURE"] },
    "freshness": { "type": "object" },
    "scope": { "type": "object" },
    "sources": { "type": "array" },
    "overview": { "$ref": "./overview.schema.json" },
    "cost": { "$ref": "./cost.schema.json" },
    "inventory": { "$ref": "./inventory.schema.json" },
    "reliability": { "$ref": "./health-activity.schema.json" },
    "security": { "$ref": "./defender.schema.json" },
    "network": { "$ref": "./network.schema.json" },
    "aiInsights": { "$ref": "./ai-insights.schema.json" }
  },
  "additionalProperties": false
}
