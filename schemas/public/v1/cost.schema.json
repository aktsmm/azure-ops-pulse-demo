{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aktsmm.github.io/azure-ops-pulse-demo/schemas/public/v1/cost.schema.json",
  "title": "Azure Ops Pulse public cost v1",
  "description": "Contains approximate JPY labels, percentage changes, and normalized trends only.",
  "type": "object",
  "required": [
    "currentApproximate",
    "previousApproximate",
    "deltaPercent",
    "forecastApproximate",
    "budgetUsedPercent",
    "normalizedTrend",
    "categories"
  ],
  "properties": {
    "currentApproximate": { "type": "string", "pattern": "^(約¥|Unavailable)" },
    "previousApproximate": { "type": "string", "pattern": "^(約¥|Unavailable)" },
    "deltaPercent": { "type": ["number", "null"] },
    "forecastApproximate": { "type": "string", "pattern": "^(約¥|Unavailable)" },
    "budgetUsedPercent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "normalizedTrend": { "type": "array", "items": { "type": "number" } },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "approximateAmount", "sharePercent", "deltaPercent"],
        "properties": {
          "name": { "type": "string" },
          "approximateAmount": { "type": "string", "pattern": "^(約¥|Unavailable)" },
          "sharePercent": { "type": "number", "minimum": 0, "maximum": 100 },
          "deltaPercent": { "type": ["number", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
