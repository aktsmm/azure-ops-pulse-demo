{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aktsmm.github.io/azure-ops-pulse-demo/schemas/public/v1/ai-insights.schema.json",
  "title": "Azure Ops Pulse evidence-bound AI insights v1",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "severity",
      "title",
      "observation",
      "impact",
      "numericEvidence",
      "recommendedAction",
      "confidence",
      "period",
      "route"
    ],
    "properties": {
      "id": { "type": "string" },
      "severity": { "enum": ["critical", "warning", "healthy", "info"] },
      "title": { "type": "string" },
      "observation": { "type": "string" },
      "impact": { "type": "string" },
      "numericEvidence": {
        "type": "array",
        "minItems": 1,
        "maxItems": 6,
        "items": {
          "type": "object",
          "required": ["label", "value", "source"],
          "properties": {
            "label": { "type": "string" },
            "value": { "type": "string" },
            "source": {
              "type": "string",
              "pattern": "^(overview|cost|inventory|reliability|security|network)(\\.[A-Za-z0-9_-]+)+$"
            }
          },
          "additionalProperties": false
        }
      },
      "recommendedAction": { "type": "string" },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "period": { "type": "string" },
      "route": {
        "enum": [
          "/overview",
          "/cost",
          "/resources",
          "/reliability",
          "/security",
          "/network",
          "/ai-insights"
        ]
      }
    },
    "additionalProperties": false
  }
}
